@page "/aa-linea"
@using System.Threading.Tasks
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>AA - Línea</PageTitle>

<div class="container mt-4">

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <div class="crud-header-left">
            <h2 class="crud-title">
                <i class="bi bi-window-stack"></i>
                Área de Aplicación por Línea de Investigación
            </h2>
        </div>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nueva Relación
            </button>
        }
    </div>

    @* ───── ALERTA ───── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @* ───── LISTAR ───── *@
    @if (!mostrarFormulario){

        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por ID - Area Aplicación" @bind="buscarId_area" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por ID - Linea Investigación" @bind="buscarId_linea" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id"> ID - Área de aplicación</th>
                            <th>Nombre - Área de aplicación</th>
                            <th class="col-id"> ID - Línea de investigación</th>
                            <th>Nombre - Línea de investigación</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["area_aplicacion"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre_area_aplicacion"]</td>
                                <td class="col-id">
                                    <span class="id-badge">@r["linea_investigacion"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre_linea"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRelacion(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No hay relaciones activas.</p>
            </div>
        }
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                Nueva Relación AA - Línea
            </div>
            <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Área de Aplicación *</label>
                        <select class="form-select" @bind="campoIdArea">
                            <option value="" disabled selected>Seleccione una área de aplicación</option>
                            @foreach (var a in areas){
                                <option value="@a["id"]">@a["nombre"] (@a["id"])</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Línea de Investigación *</label>
                        <select class="form-select" @bind="campoIdLinea">
                            <option value="" disabled selected>Seleccione una linea de investigación</option>
                            @foreach (var l in lineas){
                                <option value="@l["id"]">@l["nombre"] (@l["id"])</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRelacion" disabled="@validacionIncompleta">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                    <small class="text-muted d-block mt-2">* Campos obligatorios (clave primaria compuesta)</small>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> areas     = new();
    private List<Dictionary<string, object?>> lineas    = new();
    private bool   cargando = true;
    private bool   mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool   exito = false;

    private int campoIdArea  = 0;
    private int campoIdLinea = 0;

    private int? buscarId_area  = null;
    private int? buscarId_linea = null;

    private bool validacionIncompleta => 
        campoIdArea <= 0 || campoIdLinea <= 0;
    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
        await CargarAreaAplicacion();
        await CargarLineaInvestigacion();
    }

    private async Task CargarAreaAplicacion(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_AREAS_APLICACION");
        areas = ok ? datos : new();
    }
    private async Task CargarLineaInvestigacion(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_LINEAS_INVESTIGACION");
        lineas = ok ? datos : new();
    }
    private async Task CargarRegistros(){
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_AA_LINEA");
        registros = ok ? datos : new();
        if (!ok){ 
            exito = false; 
            mensaje = msg; 
        }else if (registros.Count == 0){
            mensaje = "No hay relaciones activas.";
            exito = false;
        }
        cargando = false;
    }

    private void NuevoRegistro(){
        campoIdArea = 0;
        campoIdLinea = 0;
        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRelacion(){
        if (validacionIncompleta){
            exito = false;
            mensaje = "Por favor, complete todos los campos obligatorios.";
            return;
        }

        var parametros = new Dictionary<string, object?>{
            ["p_area_aplicacion"]     = campoIdArea,
            ["p_linea_investigacion"] = campoIdLinea
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_INGRESAR_AA_LINEA", parametros);
        exito   = ok;
        mensaje = ok ? "Relación creada correctamente." : $"Error al guardar: {msg}";
        if (ok){
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRelacion(Dictionary<string, object?> r){
        int areaId  = Convert.ToInt32(r["area_aplicacion"]);
        int lineaId = Convert.ToInt32(r["linea_investigacion"]);

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar la relación entre el area de aplicación '{r["nombre_area_aplicacion"]}' y la linea de investigación '{r["nombre_linea"]}'?"))
            return;

        var parametros = new Dictionary<string, object?>{
            ["p_area_aplicacion"]     = areaId,
            ["p_linea_investigacion"] = lineaId
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_AA_LINEA", parametros);
        exito   = ok;
        mensaje = ok ? "Relación eliminada correctamente." : $"Error al eliminar: {msg}";
        if (ok) 
            await CargarRegistros();
    }

    private void Cancelar(){
        mostrarFormulario = false; 
        mensaje = ""; 
    }

    private async Task Buscar(){
        if (buscarId_area == 0 && buscarId_linea == 0){
            mensaje = "Ingrese el ID del área de aplicación o el ID de la línea de investigación para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;

            var parametros = new Dictionary<string, object?>{
                 ["p_area_aplicacion"]     = buscarId_area,
                 ["p_linea_investigacion"] = buscarId_linea
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_AA_LINEA_AREA", parametros);

            registros = ok ? datos : new();

            if (!ok){ 
                exito = false; 
                mensaje = msg; 
            }else if (registros.Count == 0){
                mensaje = "No se encontraron coincidencias.";
                exito = false;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            exito = false; 
            mensaje = $"Error al buscar: {ex.Message}";
        }finally{
            cargando = false;
        }
    }

    private async Task LimpiarBusqueda(){
        buscarId_area = null;
        buscarId_linea = null;
        mensaje = ""; 
        await CargarRegistros();
    }
}
