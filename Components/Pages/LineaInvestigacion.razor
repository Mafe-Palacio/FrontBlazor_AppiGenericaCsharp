@page "/linea-investigacion"  
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS


<PageTitle>Linea de Investigación</PageTitle>


<div class="container mt-4">

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <div class="crud-header-left">
            <h2 class="crud-title">
                <i class="bi bi-journals"></i>
                Línea de Investigación
            </h2>
        </div>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nueva Línea
            </button>
        }
    </div>

    @* ───── ALERTA ───── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }


    @* -- LISTAR -- *@
    @if (!mostrarFormulario){
        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por ID" @bind="buscarId" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" placeholder="Buscar por nombre" @bind="buscarNombre" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">ID</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["id"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre"]</td>
                                <td class="td-desc">@r["descripcion"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-edit" title="Editar" @onclick="() => EditarRegistro(r)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRegistro(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No hay líneas de investigación registradas.</p>
            </div>
        }
    }


    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                <i class="bi @(editando ? "bi-pencil-square" : "bi-plus-square")"></i>
                @(editando ? "Editar Línea de Investigación" : "Nueva Línea de Investigación")
            </div>
            <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nombre</label>
                        <input class="form-input" @bind="campoNombre" maxlength="45" placeholder="Ej: Biotecnología" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Descripción</label>
                        <input class="form-input" @bind="campoDescripcion" maxlength="256" placeholder="Descripción de la línea..." />
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRegistro">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoId = 0;
    private string campoNombre = "";
    private string campoDescripcion = "";


    private int? buscarId = null;
    private string buscarNombre = "";
    private string buscarDescripcion = "";


    private bool ValidarFormulario(){
        if (string.IsNullOrWhiteSpace(campoNombre)){
            mensaje = "El nombre es obligatorio.";
            return false;
        }
       
        if (string.IsNullOrWhiteSpace(campoDescripcion)){
            mensaje = "La descripción es obligatoria.";
            return false;
        }


        return true;
    }


    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
    }


    private async Task CargarRegistros(){
        cargando = true;
        buscarId = null;
       
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_LINEAS_INVESTIGACION");
        registros = ok ? datos : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay lineas de investigación registradas.";
            exito = true;
        }
        cargando = false;
    }


    private void NuevoRegistro(){
        editando = false;
        campoNombre = "";
        campoDescripcion = "";
        mensaje = "";
        mostrarFormulario = true;
    }


    private void EditarRegistro(Dictionary<string, object?> r){
        editando = true;
        campoId = Convert.ToInt32(r["id"]);
        campoNombre = r["nombre"]?.ToString() ?? "";
        campoDescripcion = r["descripcion"]?.ToString() ?? "";
        mensaje = "";
        mostrarFormulario = true;
    }


    private async Task GuardarRegistro(){
        if (!ValidarFormulario()){
            exito = false;
            return;
        }


        var parametros = new Dictionary<string, object?>{
            ["p_nombre"] = campoNombre,
            ["p_descripcion"] = campoDescripcion
        };

        if (editando)
            parametros["p_id"] = campoId;

        string sp = editando ? "SP_ACTUALIZAR_LINEA_INVESTIGACION" : "SP_INGRESAR_LINEA_INVESTIGACION";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, parametros);
        exito   = ok;
        mensaje = ok
            ? (editando ? "Linea actualizada." : "Linea creada.")
            : $"Error: {msg}";
        if (ok) { mostrarFormulario = false; await CargarRegistros(); }
    }


    private async Task EliminarRegistro(Dictionary<string, object?> r){
        int id = Convert.ToInt32(r["id"]);
        String nombre = r["nombre"]?.ToString() ?? "";


        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar la linea de investigación '{nombre}'?"))
            return;


        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_LINEA_INVESTIGACION", new() { ["p_id"] = id });
       
        exito = ok;    
        mensaje = ok ? "Linea eliminada." : $"Error: {msg}";
        if (ok)
            await CargarRegistros();
    }


    private void Cancelar(){
        mostrarFormulario = false;
        mensaje = "";
    }


    private async Task Buscar(){
        if (string.IsNullOrWhiteSpace(buscarNombre) && buscarId == null && string.IsNullOrWhiteSpace(buscarDescripcion)){
            mensaje = "Ingrese un ID o nombre o descripción para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;

            var parametros = new Dictionary<string, object?>{
                ["p_id"] = buscarId,
                ["p_nombre"] = string.IsNullOrWhiteSpace(buscarNombre) ? null : buscarNombre,
                ["p_descripcion"] = string.IsNullOrWhiteSpace(buscarDescripcion) ? null : buscarDescripcion
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_LINEA_INVESTIGACION_POR_ID_NOMBRE_DESCRIPCION", parametros);
           
            registros = ok ? datos : new();
           
            if (!ok) {
                exito = false;
                mensaje = msg;
            } else if (registros.Count == 0) {
                exito = false;
                mensaje = "No se encontraron registros que coincidan con la búsqueda.";
            } else {
                exito = true;
                mensaje = $"Se encontraron {registros.Count} registro(s) que coinciden con la búsqueda.";
            }
        }catch (Exception ex){
            exito = false;
            mensaje = $"Error al buscar: {ex.Message}";
        }finally{
            cargando = false;
        }
    }


    private async Task LimpiarBusqueda(){
        buscarId = null;
        buscarNombre = "";
        buscarDescripcion = "";
        mensaje = "";
         await CargarRegistros();
    }
}

