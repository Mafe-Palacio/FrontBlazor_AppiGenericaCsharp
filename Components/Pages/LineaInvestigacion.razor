@page "/linea-investigacion"  
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS


<PageTitle>Linea de Investigación</PageTitle>


<div class="container mt-4">
    <h3>Linea de Investigación</h3>


    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }


    @* -- LISTAR -- *@
    @if (!mostrarFormulario){
        <button class="btn btn-primary mb-3" @onclick= "NuevoRegistro">Nueva Linea</button>


        <div class="row mb-3">
            <div class="col-md-3">
                <input class="form-control" type="number" placeholder="Buscar por ID" @bind="buscarId" />
            </div>
            <div class="col-md-5">
                <input class="form-control" placeholder="Buscar por nombre" @bind="buscarNombre" />
            </div>
            <div class="col-md-4">
                <button class="btn btn-primary me-2" @onclick="Buscar">Buscar</button>
                <button class="btn btn-secondary" @onclick="LimpiarBusqueda">Limpiar</button>
            </div>
        </div>


        @if (cargando){
            <div class="d-flex justify-content-center my-4">
                <div class="spinner-border text-primary"></div>
            </div>
        }else if (registros.Any()){
            <table class= "table table-striped tabla-hover">
                <thead class= "table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripcion</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in registros){
                        <tr>
                            <td>@r["id"]</td>
                            <td>@r["nombre"]</td>
                            <td>@r["descripcion"]</td>
                            <td>
                                <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(r)">Editar</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(r)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }else{
        <div class= "alert alert-warning">No hay lineas de investigación activos.</div>
        }
    }


    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Linea de Investigación" : "Nueva Linea de Investigación")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">nombre</label>
                        <input class="form-control" @bind="campoNombre" maxlength="45"/>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">descripcion</label>
                        <input class="form-control" @bind="campoDescripcion" maxlength="256"/>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoId = 0;
    private string campoNombre = "";
    private string campoDescripcion = "";


    private int? buscarId = null;
    private string buscarNombre = "";
    private string buscarDescripcion = "";


    private bool ValidarFormulario(){
        if (string.IsNullOrWhiteSpace(campoNombre)){
            mensaje = "El nombre es obligatorio.";
            return false;
        }
       
        if (string.IsNullOrWhiteSpace(campoDescripcion)){
            mensaje = "La descripción es obligatoria.";
            return false;
        }


        return true;
    }


    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
    }


    private async Task CargarRegistros(){
        cargando = true;
        buscarId = null;
       
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_LINEAS_INVESTIGACION");
        registros = ok ? datos : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay lineas de investigación registradas.";
            exito = true;
        }
        cargando = false;
    }


    private void NuevoRegistro(){
        editando = false;
        campoNombre = "";
        campoDescripcion = "";
        mensaje = "";
        mostrarFormulario = true;
    }


    private void EditarRegistro(Dictionary<string, object?> r){
        editando = true;
        campoId = Convert.ToInt32(r["id"]);
        campoNombre = r["nombre"]?.ToString() ?? "";
        campoDescripcion = r["descripcion"]?.ToString() ?? "";
        mensaje = "";
        mostrarFormulario = true;
    }


    private async Task GuardarRegistro(){
        if (!ValidarFormulario()){
            exito = false;
            return;
        }


        var parametros = new Dictionary<string, object?>{
            ["p_nombre"] = campoNombre,
            ["p_descripcion"] = campoDescripcion
        };

        if (editando)
            parametros["p_id"] = campoId;

        string sp = editando ? "SP_ACTUALIZAR_LINEA_INVESTIGACION" : "SP_INGRESAR_LINEA_INVESTIGACION";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, parametros);
        exito   = ok;
        mensaje = ok
            ? (editando ? "Linea actualizada." : "Linea creada.")
            : $"Error: {msg}";
        if (ok) { mostrarFormulario = false; await CargarRegistros(); }
    }


    private async Task EliminarRegistro(Dictionary<string, object?> r){
        int id = Convert.ToInt32(r["id"]);
        String nombre = r["nombre"]?.ToString() ?? "";


        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar la linea de investigación '{nombre}'?"))
            return;


        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_LINEA_INVESTIGACION", new() { ["p_id"] = id });
       
        exito = ok;    
        mensaje = ok ? "Linea eliminada." : $"Error: {msg}";
        if (ok)
            await CargarRegistros();
    }


    private void Cancelar(){
        mostrarFormulario = false;
        mensaje = "";
    }


    private async Task Buscar(){
        if (string.IsNullOrWhiteSpace(buscarNombre) && buscarId == null && string.IsNullOrWhiteSpace(buscarDescripcion)){
            mensaje = "Ingrese un ID o nombre o descripción para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;

            var parametros = new Dictionary<string, object?>{
                ["p_id"] = buscarId,
                ["p_nombre"] = string.IsNullOrWhiteSpace(buscarNombre) ? null : buscarNombre,
                ["p_descripcion"] = string.IsNullOrWhiteSpace(buscarDescripcion) ? null : buscarDescripcion
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_LINEA_INVESTIGACION_POR_ID_NOMBRE_DESCRIPCION", parametros);
           
            registros = ok ? datos : new();
           
            if (!ok) {
                exito = false;
                mensaje = msg;
            } else if (registros.Count == 0) {
                exito = true;
                mensaje = "No se encontraron registros que coincidan con la búsqueda.";
            } else {
                exito = true;
                mensaje = $"Se encontraron {registros.Count} registro(s) que coinciden con la búsqueda.";
            }
        }catch (Exception ex){
            exito = false;
            mensaje = $"Error al buscar: {ex.Message}";
        }finally{
            cargando = false;
        }
    }


    private async Task LimpiarBusqueda(){
        buscarId = null;
        buscarNombre = "";
        buscarDescripcion = "";
        mensaje = "";
         await CargarRegistros();
    }
}

