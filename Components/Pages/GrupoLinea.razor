@page "/grupo-linea"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService2 Api

<PageTitle>Grupo - Línea de Investigación</PageTitle>

<div class="container mt-4">
    <h3>Relación Grupos - Líneas de Investigación</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">+ Nueva Relación</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                Nueva Relación
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Grupo de Investigación *</label>
                        <select class="form-control" @bind="campoGrupoInvestigacion">
                            <option value="">-- Seleccione un grupo --</option>
                            @foreach (var grupo in gruposDisponibles)
                            {
                                <option value="@grupo["id"]">@grupo["nombre"]</option>
                            }
                        </select>
                        @if (!string.IsNullOrEmpty(campoGrupoInvestigacion))
                        {
                            <small class="text-muted d-block mt-1">ID seleccionado: @campoGrupoInvestigacion</small>
                        }
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Línea de Investigación *</label>
                        <select class="form-control" @bind="campoLineaInvestigacion">
                            <option value="">-- Seleccione una línea --</option>
                            @foreach (var linea in lineasDisponibles)
                            {
                                <option value="@linea["id"]">@linea["nombre"]</option>
                            }
                        </select>
                        @if (!string.IsNullOrEmpty(campoLineaInvestigacion))
                        {
                            <small class="text-muted d-block mt-1">ID seleccionado: @campoLineaInvestigacion</small>
                        }
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro" disabled="@validacionIncompleta">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                <small class="text-muted d-block mt-2">* Campos obligatorios (clave primaria compuesta)</small>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Grupo Investigación</th>
                    <th>Línea Investigación</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombreGrupo(reg["grupo_investigacion"]?.ToString() ?? "")</td>
                        <td>@ObtenerNombreLinea(reg["linea_investigacion"]?.ToString() ?? "")</td>
                        <td>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla grupo_linea.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> gruposDisponibles = new();
    private List<Dictionary<string, object?>> lineasDisponibles = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Campos del formulario
    private string campoGrupoInvestigacion = string.Empty;
    private string campoLineaInvestigacion = string.Empty;
    private int? limite = null;

    // Validación
    private bool validacionIncompleta =>
        string.IsNullOrEmpty(campoGrupoInvestigacion) ||
        string.IsNullOrEmpty(campoLineaInvestigacion);

    protected override async Task OnInitializedAsync()
    {
        await CargarGruposInvestigacion();
        await CargarLineasInvestigacion();
        await CargarRegistros();
    }

    private async Task CargarGruposInvestigacion()
    {
        try
        {
            gruposDisponibles = await Api.ListarAsync("grupo_investigacion", null);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar grupos: {ex.Message}");
            mensaje = "Error al cargar los grupos de investigación.";
            exito = false;
        }
    }

    private async Task CargarLineasInvestigacion()
    {
        try
        {
            lineasDisponibles = await Api.ListarAsync("linea_investigacion", null);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar líneas: {ex.Message}");
            mensaje = "Error al cargar las líneas de investigación.";
            exito = false;
        }
    }

    private string ObtenerNombreGrupo(string grupoId)
    {
        if (string.IsNullOrEmpty(grupoId))
            return "N/A";
        
        var grupo = gruposDisponibles.FirstOrDefault(g => g["id"]?.ToString() == grupoId);
        return grupo?["nombre"]?.ToString() ?? grupoId;
    }

    private string ObtenerNombreLinea(string lineaId)
    {
        if (string.IsNullOrEmpty(lineaId))
            return "N/A";
        
        var linea = lineasDisponibles.FirstOrDefault(l => l["id"]?.ToString() == lineaId);
        return linea?["nombre"]?.ToString() ?? lineaId;
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("grupo_linea", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        campoGrupoInvestigacion = string.Empty;
        campoLineaInvestigacion = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["grupo_investigacion"] = campoGrupoInvestigacion,
            ["linea_investigacion"] = campoLineaInvestigacion,
            ["estado"] = 0
        };

        var resultado = await Api.CrearAsync("grupo_linea", datos);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string grupoInvestigacion = reg["grupo_investigacion"]?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("grupo_linea", "grupo_investigacion", grupoInvestigacion);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}