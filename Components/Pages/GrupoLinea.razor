@page "/grupo-linea"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Grupo - Línea de Investigación</PageTitle>

<div class="container mt-4">
    <h3>Relación Grupos - Líneas de Investigación</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* -- LISTAR -- *@
    @if (!mostrarFormulario){
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Registro</button>

        <div class="row mb-3">
            <div class="col-md-4">
                <input class="form-control" placeholder="Buscar por ID - Grupo Investigación" @bind="buscarId_grupo" />
            </div>
            <div class="col-md-4">
                <input class="form-control" type="number" placeholder="Buscar por ID - Línea Investigación" @bind="buscarId_linea" />
            </div>
            <div class="col-md-4">
                <button class="btn btn-primary me-2" @onclick="Buscar">Buscar</button>
                <button class="btn btn-secondary" @onclick="LimpiarBusqueda">Limpiar</button>
            </div>
        </div>

        @if (cargando){
            <div class="d-flex justify-content-center my-4">
                <div class="spinner-border text-primary"></div>
            </div>
        }else if (registros.Any()){
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width:80px">ID - Grupo de Investigación</th>
                        <th>Nombre - Grupo de Investigación</th>
                        <th style="width:80px">ID - Línea de Investigación</th>
                        <th>Nombre - Línea de Investigación</th>
                        <th style="width:130px" class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in registros){
                        <tr>
                            <td class="text-center">@r["grupo_investigacion"]</td>
                            <td>@r["nombre_grupo"]</td>
                            <td class="text-center">@r["linea_investigacion"]</td>
                            <td>@r["nombre_linea"]</td>
                            <td class="text-center">
                                <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(r)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }else{
            <div class="alert alert-warning">No se encontraron registros en la tabla grupo_linea.</div>
        }
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="card mb-3">
            <div class="card-header">Nuevo Registro</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Grupo de Investigación *</label>
                        <select class="form-control" @bind="campoIdGrupo">
                            <option value="" disabled selected>Seleccione un grupo de investigación</option>
                            @foreach (var g in grupos){
                                <option value="@g["id"]">@g["nombre"] (@g["id"])</option>
                            }
                        </select>
                    </div>
                    
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Línea de Investigación *</label>
                        <select class="form-control" @bind="campoIdLinea">
                            <option value="" disabled selected>Seleccione una línea de investigación</option>
                            @foreach (var l in lineas){
                                <option value="@l["id"]">@l["nombre"] (@l["id"])</option>
                            }
                        </select>
                    </div>
                    
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro" disabled="@validacionIncompleta">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                <small class="text-muted d-block mt-2">* Campos obligatorios (clave primaria compuesta)</small>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> grupos = new();
    private List<Dictionary<string, object?>> lineas = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoIdGrupo = 0;
    private int campoIdLinea = 0;
    private int? buscarId_grupo = null;
    private int? buscarId_linea = null;

    private bool validacionIncompleta =>
        campoIdGrupo == 0 || campoIdLinea == 0;

    protected override async Task OnInitializedAsync(){
        await CargarGruposLinea();
        await CargarRegistros();
    }

    private async Task CargarGruposLinea(){
        var (okG, datosG, _) = await Sp.EjecutarSpAsync("SP_LISTAR_GRUPOS_INVESTIGACION");
        grupos = okG ? datosG : new();

        var (okL, datosL, _) = await Sp.EjecutarSpAsync("SP_LISTAR_LINEAS_INVESTIGACION");
        lineas = okL ? datosL : new();
    }

    private async Task CargarRegistros(){
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_GRUPO_LINEA");
        registros = ok ? datos : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay relaciones registradas.";
            exito = true;
        }
        cargando = false;
    }

    private void NuevoRegistro(){
        campoIdGrupo = 0;
        campoIdLinea = 0;
        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRegistro(){
        if (validacionIncompleta){
            exito = false;
            mensaje = "Por favor, complete todos los campos obligatorios.";
            return;
        }

        var datos = new Dictionary<string, object?>{
            ["p_grupo_investigacion"] = campoIdGrupo,
            ["p_linea_investigacion"] = campoIdLinea,
        };

        string sp = "SP_INGRESAR_GRUPO_LINEA";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, datos);
        exito = ok;
        mensaje = ok ? "Relación guardada correctamente." : $"Error al guardar: {msg}";

        if (ok){
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int idGrupo = Convert.ToInt32(reg["grupo_investigacion"]);
        int idLinea = Convert.ToInt32(reg["linea_investigacion"]);

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Confirma que desea eliminar la relación entre el grupo de investigación '{reg["nombre_grupo"]}' y la línea de investigación '{reg["nombre_linea"]}'?"))
            return;

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_GRUPO_LINEA", new() { ["p_grupo_investigacion"] = idGrupo, ["p_linea_investigacion"] = idLinea });
        
        exito = ok;
        mensaje = ok ? "Relación eliminada correctamente." : $"Error al eliminar: {msg}";

        if (ok)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = "";
    }

    private async Task Buscar(){
        if (buscarId_grupo == 0 && buscarId_linea == 0){
            mensaje = "Ingrese el ID de grupo o línea de investigación.";
            exito = false;
            return;
        }

        try{
            cargando = true;
            var parametros = new Dictionary<string, object?>{
                ["p_grupo_investigacion"] = buscarId_grupo == 0 ? null : buscarId_grupo,
                ["p_linea_investigacion"] = buscarId_linea == 0 ? null : buscarId_linea
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_BUSCAR_GRUPO_LINEA", parametros);
            
            registros = ok ? datos : new();

            if (!ok){ 
                exito = false;
                mensaje = msg; 
            }else if (registros.Count == 0){
                mensaje = "No se encontraron coincidencias.";
                exito = true;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            exito = false;
            mensaje = $"Error al buscar: {ex.Message}";
        }finally{
        cargando = false;
        }
    }

    private async Task LimpiarBusqueda(){
        buscarId_grupo = null;
        buscarId_linea = null;
        mensaje = "";
        await CargarRegistros();
    }
}