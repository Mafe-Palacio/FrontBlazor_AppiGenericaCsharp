@page "/area-conocimiento"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS

<PageTitle>Áreas de Conocimiento</PageTitle>

<div class="container mt-4">
    <h3>Áreas de Conocimiento</h3>

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <h2 class="crud-title">
            <i class="bi bi-journal-text"></i>
            Areas de Conocimiento
        </h2>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nueva Área de Conocimiento
            </button>
        }
    </div>

    @* ───── ALERTA ───── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @* -- LISTAR -- *@
    @if (!mostrarFormulario){

        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por ID" @bind="buscarId" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" placeholder="Buscar por área" @bind="buscarArea" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" placeholder="Buscar por disciplina" @bind="buscarDisciplina" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">ID</th>
                            <th>Gran Área</th>
                            <th>Área</th>
                            <th>Disciplina</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["id"]</span>
                                </td>
                                <td>@r["gran_area"]</td>
                                <td>@r["area"]</td>
                                <td class="td-nombre">@r["disciplina"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-edit" title="Editar" @onclick="() => EditarRegistro(r)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRegistro(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No se encontraron registros en la tabla area_conocimiento.</p>
            </div>
        }
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                <i class="bi @(editando ? "bi-pencil-square" : "bi-plus-square")"></i>
                @(editando ? "Editar Área de Conocimiento" : "Nueva Área de Conocimiento")
            </div>
            <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">ID</label>
                        <input class="form-input" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Gran Área</label>
                        <input class="form-input" @bind="campoGranArea" maxlength="60" placeholder="Ej: Ciencias Exactas" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Área</label>
                        <input class="form-input" @bind="campoArea" maxlength="60" placeholder="Ej: Matemáticas" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Disciplina</label>
                        <input class="form-input" @bind="campoDisciplina" maxlength="60" placeholder="Ej: Matemáticas Puras" />
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRegistro">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoId = 0;
    private string campoGranArea = "";
    private string campoArea = "";
    private string campoDisciplina = "";

    private int? buscarId = null;
    private string buscarArea = "";
    private string buscarDisciplina = "";

    private bool ValidarFormulario(){
        if (campoId <= 0){
            mensaje = "El campo ID es obligatorio y debe ser un número positivo.";
            return false;
        }
        if (string.IsNullOrWhiteSpace(campoGranArea)){
            mensaje = "El campo gran área es obligatorio.";
            return false;
        }
        if (string.IsNullOrWhiteSpace(campoArea)){
            mensaje = "El campo área es obligatorio.";
            return false;
        }
        if (string.IsNullOrWhiteSpace(campoDisciplina)){
            mensaje = "El campo disciplina es obligatorio.";
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
    }

    private async Task CargarRegistros(){
        cargando = true;
        buscarId = null;
        var (ok, dato, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_AREAS_CONOCIMIENTO");
        registros = ok ? dato : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay áreas de conocimiento registradas.";
            exito = true;
        }
        cargando = false;
    }

    private void NuevoRegistro(){
        editando = false;
        campoId = 0;
        campoGranArea = "";
        campoArea = "";
        campoDisciplina = "";
        mostrarFormulario = true;
        mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg){
        editando = true;
        campoId = Convert.ToInt32(reg["id"]);
        campoGranArea = reg["gran_area"]?.ToString() ?? "";
        campoArea = reg["area"]?.ToString() ?? "";
        campoDisciplina = reg["disciplina"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRegistro(){
        if (!ValidarFormulario()){
            exito = false;
            return;
        }

        var datos = new Dictionary<string, object?>{
            ["p_id"]         = campoId,
            ["p_gran_area"]  = campoGranArea,
            ["p_area"]       = campoArea,
            ["p_disciplina"] = campoDisciplina
        };

        string sp = editando ? "SP_ACTUALIZAR_AREA_CONOCIMIENTO" : "SP_INGRESAR_AREA_CONOCIMIENTO";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, datos);
        exito = ok;
        mensaje = ok
            ? (editando ? "Área actualizada exitosamente." : "Área creada exitosamente.")
            : $"Error: {msg}";
        if (ok){
            await CargarRegistros();
            mostrarFormulario = false;
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg){
        int id = Convert.ToInt32(reg["id"]);
        string nombre = reg["area"]?.ToString() ?? "";

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Confirma que desea eliminar el área de conocimiento '{nombre}'?"))
            return;

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_AREA_CONOCIMIENTO", new() { ["p_id"] = id });

        exito = ok;
        mensaje = ok ? "Área eliminada exitosamente." : $"Error: {msg}";

        if (ok)
            await CargarRegistros();
    }

    private void Cancelar(){
        mostrarFormulario = false;
        mensaje = "";
    }

    private async Task Buscar(){
        if (buscarId == null && string.IsNullOrWhiteSpace(buscarArea) && string.IsNullOrWhiteSpace(buscarDisciplina)){
            mensaje = "Ingrese un ID, área o disciplina para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;

            var parametros = new Dictionary<string, object?>{
                ["p_id"]          = buscarId,
                ["p_area"]        = string.IsNullOrWhiteSpace(buscarArea)        ? null : buscarArea,
                ["p_disciplina"]  = string.IsNullOrWhiteSpace(buscarDisciplina)  ? null : buscarDisciplina
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_AREA_CONOCIMIENTO_POR_ID_AREA_DISCIPLINA", parametros);

            registros = ok ? datos : new();

            if (!ok){
                exito = false;
                mensaje = $"Error: {msg}";
            }else if (registros.Count == 0){
                mensaje = "No se encontraron registros que coincidan con la búsqueda.";
                exito = false;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            mensaje = $"Error al buscar: {ex.Message}";
            exito = false;
        }finally{
            cargando = false;
        }
    }

    private async Task LimpiarBusqueda(){
        buscarId = null;
        buscarArea = "";
        buscarDisciplina = "";
        mensaje = "";
        await CargarRegistros();
    }
}
