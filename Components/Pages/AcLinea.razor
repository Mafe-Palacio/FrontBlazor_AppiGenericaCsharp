@page "/ac-linea"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>AC - Línea</PageTitle>

<div class="crud-wrapper">

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <h2 class="crud-title">
            <i class="bi bi-window-stack"></i>
            Área de Conocimiento por Línea de Investigación
        </h2>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nueva Relación
            </button>
        }
    </div>

    @* ───── ALERTA ───── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        var iconoAlert = exito ? "bi-check-circle" : "bi-exclamation-circle";
        var claseAlert = exito ? "alert-ok" : "alert-err";
        <div class="alert-custom @claseAlert">
            <i class="bi @iconoAlert"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @* ───── LISTA ───── *@
    @if (!mostrarFormulario){
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="ID - Línea de Investigación" @bind="buscarId_linea" />
            </div>
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="ID - Área de Conocimiento" @bind="buscarId_area" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">ID Línea</th>
                            <th>Nombre - Línea de Investigación</th>
                            <th class="col-id">ID AC</th>
                            <th>Nombre - Área de Conocimiento</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id"><span class="id-badge">@r["linea_investigacion"]</span></td>
                                <td class="td-nombre">@r["nombre_linea"]</td>
                                <td class="col-id"><span class="id-badge">@r["area_conocimiento"]</span></td>
                                <td class="td-desc">@r["nombre_area"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRelacion(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No hay relaciones activas.</p>
            </div>
        }
    }

    @* ───── FORMULARIO ───── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                <i class="bi bi-plus-square"></i>
                Nueva Relación AC — Línea
            </div>
            <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Línea de Investigación *</label>
                        <select class="form-input" @bind="campoIdLinea">
                            <option value="0" disabled>Seleccione una línea de investigación</option>
                            @foreach (var l in lineas){
                                <option value="@l["id"]">@l["nombre"] (@l["id"])</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Área de Conocimiento *</label>
                        <select class="form-input" @bind="campoIdArea">
                            <option value="0" disabled>Seleccione un área de conocimiento</option>
                            @foreach (var a in areas){
                                <option value="@a["id"]">@a["disciplina"] (@a["id"])</option>
                            }
                        </select>
                    </div>
                </div>
                <small style="font-size:0.78rem; color:var(--text-muted); display:block; margin-bottom:1rem;">
                    * Campos obligatorios (clave primaria compuesta)
                </small>
                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRelacion" disabled="@validacionIncompleta">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> lineas    = new();
    private List<Dictionary<string, object?>> areas     = new();
    private bool   cargando = true;
    private bool   mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool   exito = false;

    private int campoIdLinea = 0;
    private int campoIdArea  = 0;

    private int? buscarId_linea = null;
    private int? buscarId_area  = null;

    private bool validacionIncompleta =>
        campoIdLinea == 0 || campoIdArea == 0;

    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
        await CargarLineaInvestigacion();
        await CargarAreasConocimiento();
    }

    private async Task CargarLineaInvestigacion(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_LINEAS_INVESTIGACION");
        lineas = ok ? datos : new();
    }

    private async Task CargarAreasConocimiento(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_AREAS_CONOCIMIENTO");
        areas = ok ? datos : new();
    }

    private async Task CargarRegistros(){
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_AC_LINEA");
        registros = ok ? datos : new();
        if (!ok){ exito = false; mensaje = msg; }
        else if (registros.Count == 0){ mensaje = "No hay relaciones registradas."; exito = false; }
        cargando = false;
    }

    private void NuevoRegistro(){
        campoIdLinea = 0;
        campoIdArea = 0;
        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRelacion(){
        if (validacionIncompleta){ exito = false; mensaje = "Por favor, complete todos los campos obligatorios."; return; }

        var parametros = new Dictionary<string, object?>{
            ["p_linea_investigacion"] = campoIdLinea,
            ["p_area_conocimiento"]   = campoIdArea
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_INGRESAR_AC_LINEA", parametros);
        exito   = ok;
        mensaje = ok ? "Relación creada correctamente." : $"Error al guardar: {msg}";
        if (ok){ mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRelacion(Dictionary<string, object?> r){
        int lineaId = Convert.ToInt32(r["linea_investigacion"]);
        int areaId  = Convert.ToInt32(r["area_conocimiento"]);

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar la relación entre la línea '{r["nombre_linea"]}' y el área '{r["nombre_area"]}'?"))
            return;

        var parametros = new Dictionary<string, object?>{
            ["p_linea_investigacion"] = lineaId,
            ["p_area_conocimiento"]   = areaId
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_AC_LINEA", parametros);
        exito   = ok;
        mensaje = ok ? "Relación eliminada correctamente." : $"Error al eliminar: {msg}";
        if (ok) await CargarRegistros();
    }

    private void Cancelar(){ mostrarFormulario = false; mensaje = ""; }

    private async Task Buscar(){
        if (buscarId_linea == 0 && buscarId_area == 0){
            mensaje = "Ingrese el ID de línea de investigación o el ID de área de conocimiento para buscar.";
            exito = false;
            return;
        }
        try{
            cargando = true;
            var parametros = new Dictionary<string, object?>{
                ["p_linea_investigacion"] = buscarId_linea == 0 ? null : buscarId_linea,
                ["p_area_conocimiento"]   = buscarId_area == 0 ? null : buscarId_area
            };
            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_AC_LINEA_AREA", parametros);
            registros = ok ? datos : new();
            if (!ok){ exito = false; mensaje = msg; }
            else if (registros.Count == 0){ exito = false; mensaje = "No se encontraron coincidencias."; }
            else { exito = true; mensaje = $"Se encontraron {registros.Count} coincidencias."; }
        }catch (Exception ex){ exito = false; mensaje = $"Error al buscar: {ex.Message}"; }
        finally{ cargando = false; }
    }

    private async Task LimpiarBusqueda(){
        buscarId_linea = null;
        buscarId_area = null;
        mensaje = "";
        await CargarRegistros();
    }
}
