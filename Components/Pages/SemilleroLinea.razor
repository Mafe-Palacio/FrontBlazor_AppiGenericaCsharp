@page "/semillero-linea"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Semillero - Línea de Investigación</PageTitle>

<div class="container mt-4">

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <div class="crud-header-left">
            <h2 class="crud-title">
                <i class="bi bi-journals"></i>
                Semilleros por Líneas de Investigación
            </h2>
        </div>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nueva Relación
            </button>
        }
    </div>

    @* ───── ALERTA ───── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @* ───── LISTAR ───── *@
    @if (!mostrarFormulario){

        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input class="search-input" type="number" placeholder="Buscar por ID - Semillero" @bind="buscarId_semillero" />
            </div>
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input class="search-input" type="number" placeholder="Buscar por ID - Línea Investigación" @bind="buscarId_linea" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

         @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">ID - Semillero</th>
                            <th>Nombre - Semillero</th>
                            <th class="col-id">ID - Línea de Investigación</th>
                            <th>Nombre - Línea de Investigación</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["semillero"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre_semillero"]</td>
                                <td class="col-id">
                                    <span class="id-badge">@r["linea_investigacion"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre_linea"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRelacion(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No hay relaciones activas.</p>
            </div>
        }
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                Nueva Relación Semillero - Línea
            </div>
           <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Semillero *</label>
                        <select class="form-input" @bind="campoIdSemillero">
                            <option value="0" disabled selected>-- Seleccione un semillero --</option>
                            @foreach (var s in semilleros){
                                <option value="@s["id"]">@s["nombre"] (@s["id"])</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Línea de Investigación *</label>
                        <select class="form-input" @bind="campoIdLinea">
                            <option value="0" disabled selected>-- Seleccione una línea de investigación --</option>
                            @foreach (var l in lineas){
                                <option value="@l["id"]">@l["nombre"] (@l["id"])</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRelacion" disabled="@validacionIncompleta">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                    <small class="text-muted d-block mt-2">* Campos obligatorios (clave primaria compuesta)</small>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros   = new();
    private List<Dictionary<string, object?>> semilleros  = new();
    private List<Dictionary<string, object?>> lineas      = new();
    private bool   cargando = true;
    private bool   mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool   exito = false;

    private int campoIdSemillero = 0;
    private int campoIdLinea     = 0;

    private int? buscarId_semillero = null;
    private int? buscarId_linea     = null;

    private bool validacionIncompleta =>
        campoIdSemillero <= 0 || campoIdLinea <= 0;

    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
        await CargarSemilleros();
        await CargarLineasInvestigacion();
    }

    private async Task CargarSemilleros(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_SEMILLEROS");
        semilleros = ok ? datos : new();
    }

    private async Task CargarLineasInvestigacion(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_LINEAS_INVESTIGACION");
        lineas = ok ? datos : new();
    }

    private async Task CargarRegistros(){
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_SEMILLERO_LINEA");
        registros = ok ? datos : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay relaciones activas.";
            exito = false;
        }
        cargando = false;
    }

    private void NuevoRegistro(){
        campoIdSemillero = 0;
        campoIdLinea     = 0;
        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRelacion(){
        if (validacionIncompleta){
            exito = false;
            mensaje = "Por favor, complete todos los campos obligatorios.";
            return;
        }

        var parametros = new Dictionary<string, object?>{
            ["p_semillero"]           = campoIdSemillero,
            ["p_linea_investigacion"] = campoIdLinea
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_INGRESAR_SEMILLERO_LINEA", parametros);
        exito   = ok;
        mensaje = ok ? "Relación creada correctamente." : $"Error al guardar: {msg}";
        if (ok){
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRelacion(Dictionary<string, object?> r){
        int idSemillero = Convert.ToInt32(r["semillero"]);
        int idLinea     = Convert.ToInt32(r["linea_investigacion"]);

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar la relación entre el semillero '{r["nombre_semillero"]}' y la línea de investigación '{r["nombre_linea"]}'?"))
            return;

        var parametros = new Dictionary<string, object?>{
            ["p_semillero"]           = idSemillero,
            ["p_linea_investigacion"] = idLinea
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_SEMILLERO_LINEA", parametros);
        exito   = ok;
        mensaje = ok ? "Relación eliminada correctamente." : $"Error al eliminar: {msg}";
        if (ok)
            await CargarRegistros();
    }

    private void Cancelar(){
        mostrarFormulario = false;
        mensaje = "";
    }

    private async Task Buscar(){
        if (buscarId_semillero == 0 && buscarId_linea == 0){
            mensaje = "Ingrese el ID del semillero o el ID de la línea de investigación para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;

            var parametros = new Dictionary<string, object?>{
                ["p_semillero"]           = buscarId_semillero,
                ["p_linea_investigacion"] = buscarId_linea
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_SEMILLERO_LINEA_POR_ID_LINEA", parametros);

            registros = ok ? datos : new();

            if (!ok){
                exito = false;
                mensaje = msg;
            }else if (registros.Count == 0){
                mensaje = "No se encontraron coincidencias.";
                exito = false;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            exito = false;
            mensaje = $"Error al buscar: {ex.Message}";
        }finally{
            cargando = false;
        }
    }

    private async Task LimpiarBusqueda(){
        buscarId_semillero = null;
        buscarId_linea     = null;
        mensaje = "";
        await CargarRegistros();
    }
}
