@page "/objetivo-desarrollo-sostenible"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS

<PageTitle>Objetivos de Desarrollo Sostenible</PageTitle>

<div class="container mt-4">
    <h3>Objetivos de Desarrollo Sostenible</h3>

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <h2 class="crud-title">
            <i class="bi bi-window-stack"></i>
            Objetivos de Desarrollo Sostenible
        </h2>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nuevo ODS
            </button>
        }
    </div>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @* -- LISTAR -- *@
    @if (!mostrarFormulario){

        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por ID" @bind="buscarId" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" placeholder="Buscar por nombre" @bind="buscarNombre" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" placeholder="Buscar por categoría" @bind="buscarCategoria" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">ID</th>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["id"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre"]</td>
                                <td class="td-nombre">@r["categoria"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-edit" title="Editar" @onclick="() => EditarRegistro(r)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRegistro(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No se encontraron registros en la tabla objetivo_desarrollo_sostenible.</p>
            </div>
        }
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar ODS" : "Nuevo ODS")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" maxlength="60" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Categoría</label>
                        <input class="form-control" @bind="campoCategoria" maxlength="45" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    private int campoId = 0;
    private string campoNombre = "";
    private string campoCategoria = "";

    private int? buscarId = null;
    private string buscarNombre = "";
    private string buscarCategoria = "";

    private bool ValidarFormulario(){
        if (campoId <= 0){
            mensaje = "El campo ID es obligatorio y debe ser un número positivo.";
            return false;
        }
        if (string.IsNullOrWhiteSpace(campoNombre)){
            mensaje = "El campo nombre es obligatorio.";
            return false;
        }
        if (string.IsNullOrWhiteSpace(campoCategoria)){
            mensaje = "El campo categoría es obligatorio.";
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
    }

    private async Task CargarRegistros(){
        cargando = true;
        buscarId = null;
        var (ok, dato, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_ODS");
        registros = ok ? dato : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay ODS registrados.";
            exito = true;
        }
        cargando = false;
    }

    private void NuevoRegistro(){
        editando = false;
        campoId = 0;
        campoNombre = "";
        campoCategoria = "";
        mostrarFormulario = true;
        mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg){
        editando = true;
        campoId = Convert.ToInt32(reg["id"]);
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoCategoria = reg["categoria"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRegistro(){
        if (!ValidarFormulario()){
            exito = false;
            return;
        }

        var datos = new Dictionary<string, object?>{
            ["p_id"]        = campoId,
            ["p_nombre"]    = campoNombre,
            ["p_categoria"] = campoCategoria
        };

        string sp = editando ? "SP_ACTUALIZAR_ODS" : "SP_INGRESAR_ODS";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, datos);
        exito = ok;
        mensaje = ok
            ? (editando ? "ODS actualizado exitosamente." : "ODS creado exitosamente.")
            : $"Error: {msg}";
        if (ok){
            await CargarRegistros();
            mostrarFormulario = false;
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg){
        int id = Convert.ToInt32(reg["id"]);
        string nombre = reg["nombre"]?.ToString() ?? "";

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Confirma que desea eliminar el ODS '{nombre}'?"))
            return;

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_ODS", new() { ["p_id"] = id });

        exito = ok;
        mensaje = ok ? "ODS eliminado exitosamente." : $"Error: {msg}";

        if (ok)
            await CargarRegistros();
    }

    private void Cancelar(){
        mostrarFormulario = false;
        mensaje = "";
    }

    private async Task Buscar(){
        if (buscarId == null && string.IsNullOrWhiteSpace(buscarNombre) && string.IsNullOrWhiteSpace(buscarCategoria)){
            mensaje = "Ingrese un ID, nombre o categoría para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;

            var parametros = new Dictionary<string, object?>{
                ["p_id"]        = buscarId,
                ["p_nombre"]    = string.IsNullOrWhiteSpace(buscarNombre)    ? null : buscarNombre,
                ["p_categoria"] = string.IsNullOrWhiteSpace(buscarCategoria) ? null : buscarCategoria
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_ODS_POR_ID_NOMBRE_CATEGORIA", parametros);

            registros = ok ? datos : new();

            if (!ok){
                exito = false;
                mensaje = $"Error: {msg}";
            }else if (registros.Count == 0){
                mensaje = "No se encontraron registros que coincidan con la búsqueda.";
                exito = false;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            mensaje = $"Error al buscar: {ex.Message}";
            exito = false;
        }finally{
            cargando = false;
        }
    }

    private async Task LimpiarBusqueda(){
        buscarId = null;
        buscarNombre = "";
        buscarCategoria = "";
        mensaje = "";
        await CargarRegistros();
    }
}
