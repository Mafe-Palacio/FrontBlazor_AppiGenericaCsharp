@page "/semillero"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS

<PageTitle>Semilleros</PageTitle>

<div class="container mt-4">

    @* ───────── HEADER ───────── *@
    <div class="crud-header">
        <h2 class="crud-title">
            <i class="bi bi-journal-text"></i>
            Semilleros
        </h2>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nuevo Semillero
            </button>
        }
    </div>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @* ───────── LISTA ───────── *@
    @if (!mostrarFormulario){
        
        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input class="search-input" type="number" placeholder="Buscar por ID" @bind="buscarId" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" placeholder="Buscar por nombre" @bind="buscarNombre" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">ID</th>
                            <th>Nombre</th>
                            <th>Fecha Fundación</th>
                            <th>Grupo</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros)
                        {
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["id"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre"]</td>
                                <td class="td-desc">@r["fecha_fundacion"]</td>
                                <td class="td-nombre">@r["nombre_grupo"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-edit" title="Editar" @onclick="() => EditarRegistro(r)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRegistro(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No hay semilleros activos.</p>
            </div>
        }
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                <i class="bi @(editando ? "bi-pencil-square" : "bi-plus-square")"></i>
                @(editando ? "Editar Semillero" : "Nuevo Semillero")
            </div>
            <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">ID</label>
                        <input class="form-input" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nombre</label>
                        <input class="form-input" @bind="campoNombre" maxlength="60" placeholder="Nombre del semillero" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha Fundación</label>
                        <input class="form-input" type="date" @bind="campoFecha" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Grupo de Investigación</label>
                        <select class="form-input" @bind="campoGrupo">
                            <option value="0" disabled selected>-- Seleccione --</option>
                            @foreach (var g in grupos){
                                <option value="@g["id"]">@g["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRegistro">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> grupos    = new();
    private bool   cargando          = true;
    private bool   mostrarFormulario = false;
    private bool   editando          = false;
    private string mensaje           = string.Empty;
    private bool   exito             = false;

    private int      campoId     = 0;
    private string   campoNombre = "";
    private DateTime campoFecha  = DateTime.Today;
    private int      campoGrupo  = 0;

    private int? buscarId = null;
    private string buscarNombre = "";

    private bool ValidarFormulario(){
        if (string.IsNullOrWhiteSpace(campoNombre)){
            mensaje = "El nombre es obligatorio.";
            return false;
        }

        if (campoGrupo <= 0){
            mensaje = "Seleccione un grupo de investigación.";
            return false;
        }

        return true;
    }


    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
        await CargarGrupos();
    }

    private async Task CargarRegistros(){
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_SEMILLEROS");
        registros = ok ? datos : new();
        if (!ok) { exito = false; mensaje = msg; }
        cargando = false;
    }

    private async Task CargarGrupos(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_GRUPOS_INVESTIGACION");
        grupos = ok ? datos : new();
    }

    private async Task NuevoRegistro(){
        editando = false;
        campoId = 0; 
        campoNombre = "";
        campoFecha = DateTime.Today; 
        campoGrupo = 0;
        await CargarGrupos();
        mensaje = ""; 
        mostrarFormulario = true;
    }

    private async Task EditarRegistro(Dictionary<string, object?> r){
        editando    = true;
        campoId     = Convert.ToInt32(r["id"]);
        campoNombre = r["nombre"]?.ToString() ?? "";
        campoGrupo  = Convert.ToInt32(r["grupo_investigacion"]);
        if (DateTime.TryParse(r["fecha_fundacion"]?.ToString(), out var f)) campoFecha = f;
        await CargarGrupos();
        mensaje = ""; 
        mostrarFormulario = true;
    }

    private async Task GuardarRegistro(){
        if(!ValidarFormulario()){
            exito = false;
            return;
        }

        var parametros = new Dictionary<string, object?>{
            ["p_id"]                  = campoId,
            ["p_nombre"]              = campoNombre,
            ["p_fecha_fundacion"]     = campoFecha.ToString("yyyy-MM-dd"),
            ["p_grupo_investigacion"] = campoGrupo
        };

        string sp = editando ? "SP_ACTUALIZAR_SEMILLERO" : "SP_INGRESAR_SEMILLERO";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, parametros);
        exito   = ok;
        mensaje = ok
            ? (editando ? "Semillero actualizado." : "Semillero creado.")
            : $"Error: {msg}";
        if (ok){
            mostrarFormulario = false; 
            await CargarRegistros(); 
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> r){
        int id = Convert.ToInt32(r["id"]);
        string nombre = r["nombre"]?.ToString() ?? "";
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar el semillero '{nombre}'?"))
            return;

        var (ok, _, msg) = await Sp.EjecutarSpAsync(
            "SP_ELIMINAR_SEMILLERO",
            new() { ["p_id"] = id });

        exito   = ok;
        mensaje = ok ? "Semillero eliminado." : $"Error: {msg}";
        if (ok) await CargarRegistros();
    }

    private void Cancelar(){
        mostrarFormulario = false; 
        mensaje = ""; 
    }

    private async Task Buscar(){
        if (buscarId == null && string.IsNullOrWhiteSpace(buscarNombre)){
            mensaje = "Ingrese el ID o nombre para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;
             
            var parametros = new Dictionary<string, object?>{
                 ["p_id"] = buscarId,
                 ["p_nombre"] = string.IsNullOrWhiteSpace(buscarNombre) ? null : buscarNombre
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_SEMILLERO_POR_ID_NOMBRE", parametros);
            
            registros = ok ? datos : new();
             if (!ok){ 
                exito = false; 
                mensaje = msg; 
            }else if (registros.Count == 0){
                mensaje = "No se encontraron coincidencias.";
                exito = false;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            exito = false; 
            mensaje = $"Error al buscar: {ex.Message}";
        }finally{
            cargando = false;
        }
    }

    private async Task LimpiarBusqueda(){
        buscarId = null;
        buscarNombre = "";
        mensaje = "";
        await CargarRegistros();     
    }
}
