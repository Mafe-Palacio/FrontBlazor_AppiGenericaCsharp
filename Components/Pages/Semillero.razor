@page "/semillero"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS

<PageTitle>Semilleros</PageTitle>

<div class="container mt-4">
    <h3>Semilleros</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* -- LISTAR -- *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Semillero</button>

        @if (cargando)
        {
            <p>Cargando...</p>
        }
        else if (registros.Any())
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Fecha Fundación</th>
                        <th>Grupo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in registros)
                    {
                        <tr>
                            <td>@r["id"]</td>
                            <td>@r["nombre"]</td>
                            <td>@r["fecha_fundacion"]</td>
                            <td>@r["nombre_grupo"]</td>
                            <td>
                                <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(r)">Editar</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(r)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-warning">No hay semilleros activos.</div>
        }
    }

    @* -- FORMULARIO -- *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Semillero" : "Nuevo Semillero")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-9 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" maxlength="60" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Fundación</label>
                        <input class="form-control" type="date" @bind="campoFecha" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Grupo de Investigación</label>
                        <select class="form-select" @bind="campoGrupo">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var g in grupos)
                            {
                                <option value="@g["id"]">@g["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> grupos    = new();
    private bool   cargando          = true;
    private bool   mostrarFormulario = false;
    private bool   editando          = false;
    private string mensaje           = string.Empty;
    private bool   exito             = false;

    private int      campoId     = 0;
    private string   campoNombre = "";
    private DateTime campoFecha  = DateTime.Today;
    private int      campoGrupo  = 0;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
        await CargarGrupos();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_SEMILLEROS");
        registros = ok ? datos : new();
        if (!ok) { exito = false; mensaje = msg; }
        cargando = false;
    }

    private async Task CargarGrupos()
    {
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_GRUPOS_INVESTIGACION");
        grupos = ok ? datos : new();
    }

    private async Task NuevoRegistro()
    {
        editando = false;
        campoId = 0; campoNombre = "";
        campoFecha = DateTime.Today; campoGrupo = 0;
        await CargarGrupos();
        mensaje = ""; mostrarFormulario = true;
    }

    private async Task EditarRegistro(Dictionary<string, object?> r)
    {
        editando    = true;
        campoId     = Convert.ToInt32(r["id"]);
        campoNombre = r["nombre"]?.ToString() ?? "";
        campoGrupo  = Convert.ToInt32(r["grupo_investigacion"]);
        if (DateTime.TryParse(r["fecha_fundacion"]?.ToString(), out var f)) campoFecha = f;
        await CargarGrupos();
        mensaje = ""; mostrarFormulario = true;
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrWhiteSpace(campoNombre))
        {
            mensaje = "El nombre es obligatorio.";
            exito = false;
            return;
        }
        if (campoGrupo <= 0)
        {
            mensaje = "Seleccione un grupo.";
            exito = false;
            return;
        }

        var parametros = new Dictionary<string, object?>
        {
            ["p_id"]                  = campoId,
            ["p_nombre"]              = campoNombre,
            ["p_fecha_fundacion"]     = campoFecha.ToString("yyyy-MM-dd"),
            ["p_grupo_investigacion"] = campoGrupo
        };

        string sp = editando ? "SP_ACTUALIZAR_SEMILLERO" : "SP_INGRESAR_SEMILLERO";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, parametros);
        exito   = ok;
        mensaje = ok
            ? (editando ? "Semillero actualizado." : "Semillero creado.")
            : $"Error: {msg}";
        if (ok) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> r)
    {
        int    id     = Convert.ToInt32(r["id"]);
        string nombre = r["nombre"]?.ToString() ?? "";
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar el semillero '{nombre}'?"))
            return;

        var (ok, _, msg) = await Sp.EjecutarSpAsync(
            "SP_ELIMINAR_SEMILLERO",
            new() { ["p_id"] = id });

        exito   = ok;
        mensaje = ok ? "Semillero eliminado." : $"Error: {msg}";
        if (ok) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = ""; }
}
