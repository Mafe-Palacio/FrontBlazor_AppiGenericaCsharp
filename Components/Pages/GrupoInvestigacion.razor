@page "/grupo-investigacion"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Grupos de Investigación</PageTitle>

<div class="container mt-4">
    <h3>Grupos de Investigación</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* -- LISTAR -- *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Grupo</button>

        @if (cargando)
        {
            <p>Cargando...</p>
        }
        else if (registros.Any())
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Convocatoria</th>
                        <th>Fundación</th>
                        <th>Universidad</th>
                        <th>Ámbito</th>
                        <th>Interno</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in registros)
                    {
                        <tr>
                            <td>@r["id"]</td>
                            <td>@r["nombre"]</td>
                            <td>@r["categoria"]</td>
                            <td>@r["convocatoria"]</td>
                            <td>@r["fecha_fundacion"]</td>
                            <td>@r["nombre_universidad"]</td>
                            <td>@r["ambito"]</td>
                            <td>
                                @(Convert.ToBoolean(r["interno"]) ? "Sí" : "No")
                            </td>
                            <td>
                                <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(r)">Editar</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(r)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-warning">No hay grupos de investigación activos.</div>
        }
    }

    @* -- FORMULARIO -- *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Grupo de Investigación" : "Nuevo Grupo de Investigación")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-9 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" maxlength="60" />
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label">URL GrupLAC</label>
                        <input class="form-control" @bind="campoUrl" maxlength="128" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Categoría</label>
                        <select class="form-select" @bind="campoCategoria">
                            <option value="" disabled selected>Seleccione una categoría</option>
                            @foreach (var c in categorias){
                                <option value= "@c["categoria"]?.ToString()">@c["categoria"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Convocatoria</label>
                        <input class="form-control" @bind="campoConvocatoria" maxlength="10" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fundación</label>
                        <input class="form-control" type="date" @bind="campoFecha" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Universidad</label>
                        <select class="form-select" @bind="campoUniversidad">
                            @foreach (var u in universidades)
                            {
                                <option value="@u["id"]">@u["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Ámbito</label>
                        <select class="form-select" @bind="campoAmbito">
                            <option>Nacional</option>
                            <option>Internacional</option>
                            <option>Regional</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="campoInterno" />
                            <label class="form-check-label">¿Interno?</label>
                        </div>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros     = new();
    private List<Dictionary<string, object?>> universidades = new();
    private List<Dictionary<string, object?>> categorias = new();
    private bool   cargando          = true;
    private bool   mostrarFormulario = false;
    private bool   editando          = false;
    private string mensaje           = string.Empty;
    private bool   exito             = false;

    private int      campoId           = 0;
    private string   campoNombre       = "";
    private string   campoUrl          = "";
    private string   campoCategoria    = "";
    private string   campoConvocatoria = "";
    private DateTime campoFecha        = DateTime.Today;
    private int      campoUniversidad  = 0;
    private bool     campoInterno      = true;
    private string   campoAmbito       = "Nacional";

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
        await CargarUniversidades();
        await CargarCategorias();    
    }

    private async Task CargarCategorias(){
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_CATEGORIA_GRUPO_INVESTIGACION");
        categorias = ok ? datos : new();
    }

    private async Task CargarUniversidades()
    {
        var (ok, datos, _) = await Sp.EjecutarSpAsync("SP_LISTAR_UNIVERSIDADES");
        universidades = ok ? datos : new();
    }
    private async Task CargarRegistros()
    {
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_GRUPOS_INVESTIGACION");
        registros = ok ? datos : new();
        if (!ok) { exito = false; mensaje = msg; }
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = 0; 
        campoNombre = ""; 
        campoUrl = "";
        campoCategoria = ""; 
        campoConvocatoria = "";
        campoFecha = DateTime.Today;
        campoUniversidad = 0; 
        campoInterno = true; 
        campoAmbito = "Nacional";
        mensaje = ""; 
        mostrarFormulario = true;
    }

    private void EditarRegistro(Dictionary<string, object?> r)
    {
        editando = true;
        campoId = Convert.ToInt32(r["id"]);
        campoNombre = r["nombre"]?.ToString() ?? "";
        campoUrl = r["url_gruplac"]?.ToString() ?? "";
        campoCategoria = r["categoria"]?.ToString() ?? "";
        campoConvocatoria = r["convocatoria"]?.ToString() ?? "";
        campoUniversidad = r["universidad"] != null ? Convert.ToInt32(r["universidad"]) : 0;
        campoInterno = r["interno"]?.ToString() == "1";
        campoAmbito = r["ambito"]?.ToString() ?? "Nacional";
        if (DateTime.TryParse(r["fecha_fundacion"]?.ToString(), out var f)) campoFecha = f;
        mensaje = ""; 
        mostrarFormulario = true;
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrWhiteSpace(campoNombre))
        {
            mensaje = "El nombre es obligatorio.";
            exito = false;
            return;
        }

        var parametros = new Dictionary<string, object?>
        {
            ["p_id"] = campoId,
            ["p_nombre"] = campoNombre,
            ["p_url_gruplac"] = string.IsNullOrWhiteSpace(campoUrl) ? null : campoUrl,
            ["p_categoria"] = campoCategoria,
            ["p_convocatoria"] = campoConvocatoria,
            ["p_fecha_fundacion"] = campoFecha.ToString("yyyy-MM-dd"),
            ["p_universidad"] = campoUniversidad == 0 ? null : (object?)campoUniversidad,
            ["p_interno"] = campoInterno,
            ["p_ambito"] = campoAmbito
        };

        string sp = editando ? "SP_ACTUALIZAR_GRUPO_INVESTIGACION" : "SP_INGRESAR_GRUPO_INVESTIGACION";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, parametros);
        exito   = ok;
        mensaje = ok
            ? (editando ? "Grupo actualizado." : "Grupo creado.")
            : $"Error: {msg}";
        if (ok) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> r)
    {
        int    id     = Convert.ToInt32(r["id"]);
        string nombre = r["nombre"]?.ToString() ?? "";
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar el grupo '{nombre}' y sus semilleros?"))
            return;

        var (ok, _, msg) = await Sp.EjecutarSpAsync(
            "SP_ELIMINAR_GRUPO_INVESTIGACION",
            new() { ["p_id"] = id });

        exito   = ok;
        mensaje = ok ? "Grupo eliminado." : $"Error: {msg}";
        if (ok) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = ""; }
}
