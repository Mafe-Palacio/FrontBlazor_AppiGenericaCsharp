@page "/area-aplicacion"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject IJSRuntime JS


<PageTitle>Areas de Aplicación</PageTitle>


<div class="container mt-4">

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <h2 class="crud-title">
            <i class="bi bi-file-earmark-text"></i>
            Areas de Aplicación
        </h2>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nueva Área de Aplicación
            </button>
        }
    </div>


    @* ───── ALERTA ───── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }


    @* -- LISTAR -- *@
    @if (!mostrarFormulario){

        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por ID" @bind="buscarId" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input class="search-input" placeholder="Buscar por nombre" @bind="buscarNombre" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">ID</th>
                            <th>Nombre</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["id"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre"]</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-edit" title="Editar" @onclick="() => EditarRegistro(r)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRegistro(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No se encontraron registros en la tabla area_aplicacion.</p>
            </div>
        }
    }


    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                <i class="bi @(editando ? "bi-pencil-square" : "bi-plus-square")"></i>
                @(editando ? "Editar Area de Aplicación" : "Nueva Area de Aplicación")
            </div>
            <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">id</label>
                        <input class="form-input" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">nombre</label>
                        <input class="form-input" @bind="campoNombre" maxlength="60" placeholder="Nombre del área de aplicación" />
                    </div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRegistro">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                </div>
            </div>
        </div>
    }
</div>


@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;


    private int campoId = 0;
    private string campoNombre = "";


    private int? buscarId = null;
    private string buscarNombre = "";


    private bool ValidarFormulario(){
        if (campoId == 0 || campoId <= 0){
            mensaje = "El campo ID es obligatorio y debe ser un número positivo.";
            return false;
        }
       
        if (string.IsNullOrWhiteSpace(campoNombre)){
            mensaje = "El campo nombre es obligatorio.";
            return false;
        }


        return true;
    }


    protected override async Task OnInitializedAsync(){
        await CargarRegistros();
    }


    private async Task CargarRegistros(){
        cargando = true;
        var (ok, dato, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_AREAS_APLICACION");
        registros = ok ? dato : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay areas de aplicación registradas.";
            exito = true;
        }
        cargando = false;
    }


    private void NuevoRegistro(){
        editando = false;
        campoId = 0;
        campoNombre = "";
        mostrarFormulario = true;
        mensaje = "";
    }


    private void EditarRegistro(Dictionary<string, object?> reg){
        editando = true;
        campoId = reg["id"]?.ToString() != null ? Convert.ToInt32(reg["id"]) : 0;
        campoNombre = reg["nombre"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = "";
    }


    private async Task GuardarRegistro(){
        if (!ValidarFormulario()){
            exito = false;
            return;
        }
       
        var datos = new Dictionary<string, object?>{
            ["p_id"] = campoId,
            ["p_nombre"] = campoNombre
        };


        string sp = editando ? "SP_ACTUALIZAR_AREA_APLICACION" : "SP_INGRESAR_AREA_APLICACION";
        var (ok, _, msg) = await Sp.EjecutarSpAsync(sp, datos);
        exito = ok;
        mensaje = ok
            ? (editando ? "Area actualizada exitosamente." : "Area creada exitosamente.")
            : $"Error: {msg}";
        if (ok){
            await CargarRegistros();
            mostrarFormulario = false;
        }
    }


    private async Task EliminarRegistro(Dictionary<string, object?> reg){
        int id = Convert.ToInt32(reg["id"]);
        String nombre = reg["nombre"]?.ToString() ?? "";


        if (!await JS.InvokeAsync<bool>("confirm", $"¿Confirma que desea eliminar el area de aplicación '{nombre}'?"))
            return;


        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_AREA_APLICACION", new() { ["p_id"] = id });
       
        exito = ok;
        mensaje = ok ? "Area eliminada exitosamente." : $"Error: {msg}";


        if (exito)
            await CargarRegistros();
    }


    private void Cancelar(){
        mostrarFormulario = false;
        mensaje = "";
    }


    private async Task Buscar(){
        if (buscarId == null && string.IsNullOrWhiteSpace(buscarNombre)){
            mensaje = "Ingrese un ID o nombre para buscar.";
            exito = false;
            return;
        }


        try{
            cargando = true;


            var parametros = new Dictionary<string, object?>{
                ["p_id"] = buscarId,
                ["p_nombre"] = buscarNombre
            };


            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_AREA_APLICACION_POR_ID_NOMBRE", parametros);


            registros = ok ? datos : new();


            if (!ok){
                exito = false;
                mensaje = $"Error: {msg}";
            }else if (registros.Count == 0){
                mensaje = "No se encontraron registros que coincidan con la búsqueda.";
                exito = false;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            mensaje = $"Error al buscar: {ex.Message}";
            exito = false;
        }finally{
            cargando = false;
        }
    }


    private async Task LimpiarBusqueda(){
        buscarId = null;
        buscarNombre = "";
        mensaje = "";
        await CargarRegistros();
    }
   
}

