@page "/crear-grupo-completo"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService2 Api

<PageTitle>Crear Grupo de Investigación Completo</PageTitle>

<div class="container mt-4">
    <h3>Crear Grupo de Investigación Completo</h3>
    <p class="text-muted">Complete todos los campos obligatorios marcados con *</p>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── CARGANDO DATOS ───────── *@
    @if (cargando)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Cargando líneas de investigación y docentes...
        </div>
    }
    else
    {
        @* ───────── FORMULARIO ───────── *@
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Nueva Grupo de Investigación</h5>
            </div>
            <div class="card-body">

                @* Sección 1: Datos del Grupo *@
                <h6 class="mb-3 border-bottom pb-2">1. Datos del Grupo de Investigación</h6>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control" type="text" @bind="formData.nombre" disabled="@procesando" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Ámbito *</label>
                        <input class="form-control" type="text" @bind="formData.ambito" disabled="@procesando" placeholder="Ej: Local, Regional, Nacional" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha Fundación *</label>
                        <input class="form-control" type="date" @bind="formData.fecha_fundacion" disabled="@procesando" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" @bind="formData.interno" disabled="@procesando" id="interno" />
                            <label class="form-check-label" for="interno">
                                Es Grupo Interno
                            </label>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">URL GRUPLAC</label>
                        <input class="form-control" type="text" @bind="formData.url_gruplac" disabled="@procesando" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Categoría</label>
                        <input class="form-control" type="text" @bind="formData.categoria" disabled="@procesando" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Convocatoria</label>
                        <input class="form-control" type="text" @bind="formData.convocatoria" disabled="@procesando" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Universidad</label>
                        <input class="form-control" type="number" @bind="formData.universidad" disabled="@procesando" />
                    </div>
                </div>

                <hr class="my-4" />

                @* Sección 2: Líneas de Investigación *@
                <h6 class="mb-3 border-bottom pb-2">2. Líneas de Investigación</h6>
                
                <div class="row mb-3">
                    <div class="col-md-8 mb-3">
                        <label class="form-label">Seleccionar Línea</label>
                        <select class="form-control" @bind="lineaSeleccionada" disabled="@(procesando || lineasDisponibles.Count == 0)">
                            <option value="">-- Selecciona una línea --</option>
                            @foreach (var linea in lineasDisponibles)
                            {
                                <option value="@linea["id"]">@linea["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3 d-flex align-items-end">
                        <button class="btn btn-success w-100" @onclick="AgregarLinea" disabled="@(procesando || !lineaSeleccionada.HasValue || lineasAgregadas.Any(l => l.id == lineaSeleccionada))">
                            <span class="text-lg">+</span> Agregar Línea
                        </button>
                    </div>
                </div>

                @* Lista de líneas agregadas *@
                @if (lineasAgregadas.Count > 0)
                {
                    <div class="mb-3">
                        <strong>Líneas Agregadas:</strong>
                        <div class="list-group">
                            @foreach (var linea in lineasAgregadas)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@linea.nombre</span>
                                    <button class="btn btn-sm btn-danger" @onclick="() => EliminarLinea(linea.id)" disabled="@procesando">
                                        ✕ Eliminar
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <hr class="my-4" />

                @* Sección 3: Docentes Participantes *@
                <h6 class="mb-3 border-bottom pb-2">3. Docentes Participantes</h6>
                
                <div class="row mb-3">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Docente *</label>
                        <select class="form-control" @bind="docenteSeleccionado" disabled="@(procesando || docentesDisponibles.Count == 0)">
                            <option value="">-- Selecciona un docente --</option>
                            @foreach (var docente in docentesDisponibles)
                            {
                                var nombre = $"{docente["nombres"]} {docente["apellidos"]}";
                                <option value="@docente["cedula"]">@nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Rol *</label>
                        <input class="form-control" type="text" @bind="rolTemporal" disabled="@procesando" placeholder="Coordinador" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Inicio *</label>
                        <input class="form-control" type="date" @bind="fechaInicioTemporal" disabled="@procesando" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Fin</label>
                        <input class="form-control" type="date" @bind="fechaFinTemporal" disabled="@procesando" />
                    </div>
                    <div class="col-md-2 mb-3 d-flex align-items-end">
                        <button class="btn btn-success w-100" @onclick="AgregarDocente" disabled="@(procesando || !docenteSeleccionado.HasValue || string.IsNullOrWhiteSpace(rolTemporal) || !fechaInicioTemporal.HasValue || docentesAgregados.Any(d => d.cedula == docenteSeleccionado))">
                            <span class="text-lg">+</span> Agregar
                        </button>
                    </div>
                </div>

                @* Lista de docentes agregados *@
                @if (docentesAgregados.Count > 0)
                {
                    <div class="mb-3">
                        <strong>Docentes Agregados:</strong>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Docente</th>
                                        <th>Rol</th>
                                        <th>Fecha Inicio</th>
                                        <th>Fecha Fin</th>
                                        <th class="text-center">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var docente in docentesAgregados)
                                    {
                                        <tr>
                                            <td>@docente.nombre</td>
                                            <td>@docente.rol</td>
                                            <td>@docente.fecha_inicio?.ToString("dd/MM/yyyy")</td>
                                            <td>@docente.fecha_fin?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-danger" @onclick="() => EliminarDocente(docente.cedula)" disabled="@procesando">
                                                    ✕
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <hr class="my-4" />

                @* Botones de Acción *@
                <div class="d-flex gap-2">
                    <button class="btn btn-success" @onclick="GuardarGrupoCompleto" disabled="@(procesando || validacionIncompleta)">
                        @if (procesando)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Creando...</span>
                        }
                        else
                        {
                            <span>✓ Crear Grupo Completo</span>
                        }
                    </button>
                    <button class="btn btn-secondary" @onclick="LimpiarFormulario" disabled="@procesando">Limpiar</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool procesando = false;
    private bool cargando = true;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Datos cargados de la API
    private List<Dictionary<string, object?>> lineasDisponibles = new();
    private List<Dictionary<string, object?>> docentesDisponibles = new();

    // Estructuras para almacenar líneas y docentes agregados
    private class LineaSeleccionada
    {
        public int id { get; set; }
        public string nombre { get; set; } = string.Empty;
    }

    private class DocenteParticipa
    {
        public int cedula { get; set; }
        public string nombre { get; set; } = string.Empty;
        public string rol { get; set; } = string.Empty;
        public DateTime? fecha_inicio { get; set; }
        public DateTime? fecha_fin { get; set; }
    }

    private class FormGrupoCompleto
    {
        public string nombre { get; set; } = string.Empty;
        public string? url_gruplac { get; set; }
        public string? categoria { get; set; }
        public string? convocatoria { get; set; }
        public DateTime fecha_fundacion { get; set; } = DateTime.Now;
        public int? universidad { get; set; }
        public bool interno { get; set; }
        public string ambito { get; set; } = string.Empty;
    }

    private FormGrupoCompleto formData = new();
    private List<LineaSeleccionada> lineasAgregadas = new();
    private List<DocenteParticipa> docentesAgregados = new();

    // Controles para agregar líneas y docentes
    private int? lineaSeleccionada;
    private int? docenteSeleccionado;
    private string? rolTemporal;
    private DateTime? fechaInicioTemporal;
    private DateTime? fechaFinTemporal;

    // Validación
    private bool validacionIncompleta =>
        string.IsNullOrWhiteSpace(formData.nombre) ||
        formData.fecha_fundacion == default ||
        string.IsNullOrWhiteSpace(formData.ambito) ||
        lineasAgregadas.Count == 0 ||
        docentesAgregados.Count == 0;

    // ═══════════════════════════════════════════════════════════
    // CICLO DE VIDA
    // ═══════════════════════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        cargando = false;
    }

    private async Task CargarDatos()
    {
        try
        {
            // Cargar líneas de investigación
            lineasDisponibles = await Api.ListarAsync("linea_investigacion") ?? new();

            // Cargar docentes
            docentesDisponibles = await Api.ListarAsync("docente") ?? new();
        }
        catch (Exception ex)
        {
            mensaje = $"Error cargando datos: {ex.Message}";
            exito = false;
        }
    }

    // ═══════════════════════════════════════════════════════════
    // MANEJO DE LÍNEAS DE INVESTIGACIÓN
    // ═══════════════════════════════════════════════════════════

    private void AgregarLinea()
    {
        if (!lineaSeleccionada.HasValue)
            return;

        //var linea = lineasDisponibles.FirstOrDefault(l => l["id"].ToString() == lineaSeleccionada.ToString());
        var linea = lineasDisponibles.FirstOrDefault(l => l["id"]?.ToString() == lineaSeleccionada.ToString());
        if (linea != null && !lineasAgregadas.Any(l => l.id == lineaSeleccionada))
        {
            lineasAgregadas.Add(new LineaSeleccionada
            {
                id = (int)lineaSeleccionada,
                nombre = linea["nombre"]?.ToString() ?? "Desconocida"
            });

            lineaSeleccionada = null;
        }
    }

    private void EliminarLinea(int id)
    {
        lineasAgregadas.RemoveAll(l => l.id == id);
    }

    // ═══════════════════════════════════════════════════════════
    // MANEJO DE DOCENTES PARTICIPANTES
    // ═══════════════════════════════════════════════════════════

    private void AgregarDocente()
    {
        if (!docenteSeleccionado.HasValue || string.IsNullOrWhiteSpace(rolTemporal) || !fechaInicioTemporal.HasValue)
            return;

        // var docente = docentesDisponibles.FirstOrDefault(d => d["cedula"].ToString() == docenteSeleccionado.ToString());
        var docente = docentesDisponibles.FirstOrDefault(d => d["cedula"]?.ToString() == docenteSeleccionado.ToString());
        if (docente != null && !docentesAgregados.Any(d => d.cedula == docenteSeleccionado))
        {
            var nombres = docente["nombres"]?.ToString() ?? "";
            var apellidos = docente["apellidos"]?.ToString() ?? "";

            docentesAgregados.Add(new DocenteParticipa
            {
                cedula = (int)docenteSeleccionado,
                nombre = $"{nombres} {apellidos}".Trim(),
                rol = rolTemporal,
                fecha_inicio = fechaInicioTemporal,
                fecha_fin = fechaFinTemporal
            });

            // Limpiar campos temporales
            docenteSeleccionado = null;
            rolTemporal = null;
            fechaInicioTemporal = null;
            fechaFinTemporal = null;
        }
    }

    private void EliminarDocente(int cedula)
    {
        docentesAgregados.RemoveAll(d => d.cedula == cedula);
    }

    // ═══════════════════════════════════════════════════════════
    // GUARDAR GRUPO COMPLETO
    // ═══════════════════════════════════════════════════════════

    private async Task GuardarGrupoCompleto()
    {
        if (validacionIncompleta)
        {
            mensaje = "Por favor complete todos los campos obligatorios y agregue al menos una línea y un docente.";
            exito = false;
            return;
        }

        procesando = true;
        mensaje = string.Empty;

        try
        {
            // Convertir líneas a formato esperado por el SP: "1,2,3"
            var lineasIds = string.Join(",", lineasAgregadas.Select(l => l.id));

            // Convertir docentes a formato esperado
            var docentesCsv = string.Join("|", docentesAgregados.Select(d =>
                $"{d.cedula}:{d.rol}:{d.fecha_inicio:yyyy-MM-dd}:{(d.fecha_fin?.ToString("yyyy-MM-dd") ?? "")}"));

            var parametros = new Dictionary<string, object?>
            {
                ["nombre"] = formData.nombre,
                ["url_gruplac"] = formData.url_gruplac,
                ["categoria"] = formData.categoria,
                ["convocatoria"] = formData.convocatoria,
                ["fecha_fundacion"] = formData.fecha_fundacion.ToString("yyyy-MM-dd"),
                ["universidad"] = formData.universidad,
                ["interno"] = formData.interno ? 1 : 0,
                ["ambito"] = formData.ambito,
                ["estado"] = 0,
                ["lineas"] = lineasIds,
                ["docentes"] = docentesCsv
            };

            var (exitoSP, mensajeSP) = await Api.EjecutarProcedimientoAsync("sp_crear_grupo_completo", parametros);

            exito = exitoSP;
            mensaje = exitoSP
                ? "✓ Grupo de investigación creado correctamente."
                : $"✗ Error: {mensajeSP}";

            if (exito)
            {
                LimpiarFormulario();
            }
        }
        catch (Exception ex)
        {
            exito = false;
            mensaje = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            procesando = false;
        }
    }

    private void LimpiarFormulario()
    {
        formData = new();
        lineasAgregadas.Clear();
        docentesAgregados.Clear();
        lineaSeleccionada = null;
        docenteSeleccionado = null;
        rolTemporal = null;
        fechaInicioTemporal = null;
        fechaFinTemporal = null;
        mensaje = string.Empty;
    }
}