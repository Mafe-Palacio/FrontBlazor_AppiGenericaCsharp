@page "/participa-grupo"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService2 Api

<PageTitle>Participación en Grupos</PageTitle>

<div class="container mt-4">
    <h3>Participación en Grupos de Investigación</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">+ Nueva Participación</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Participación" : "Nueva Participación")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Docente *</label>
                        <select class="form-control" @bind="campoCedulaDocente" disabled="@editando">
                            <option value="">-- Seleccione un docente --</option>
                            @foreach (var docente in docentesDisponibles)
                            {
                                <option value="@docente["cedula"]">@($"{docente["nombres"]} {docente["apellidos"]}")</option>
                            }
                        </select>
                        @if (!string.IsNullOrEmpty(campoCedulaDocente))
                        {
                            <small class="text-muted d-block mt-1">Cédula: @campoCedulaDocente</small>
                        }
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Grupo de Investigación *</label>
                        <select class="form-control" @bind="campoGrupoId" disabled="@editando">
                            <option value="">-- Seleccione un grupo --</option>
                            @foreach (var grupo in gruposDisponibles)
                            {
                                <option value="@grupo["id"]">@grupo["nombre"]</option>
                            }
                        </select>
                        @if (!string.IsNullOrEmpty(campoGrupoId))
                        {
                            <small class="text-muted d-block mt-1">ID: @campoGrupoId</small>
                        }
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Rol en el Grupo</label>
                        <input class="form-control" type="text" @bind="campoRol" placeholder="Ej: Investigador Principal, Co-investigador" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha de Inicio</label>
                        <input class="form-control" type="date" @bind="campoFechaInicio" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha de Fin</label>
                        <input class="form-control" type="date" @bind="campoFechaFin" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Docente</th>
                    <th>Grupo</th>
                    <th>Rol</th>
                    <th>Inicio</th>
                    <th>Fin</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@ObtenerNombreDocente(reg["docente_cedula"]?.ToString() ?? "")</td>
                        <td>@ObtenerNombreGrupo(reg["grupo_investigacion_id"]?.ToString() ?? "")</td>
                        <td>@reg["rol"]</td>
                        <td>@(FormatearFecha(reg["fecha_inicio"]?.ToString()))</td>
                        <td>@(FormatearFecha(reg["fecha_fin"]?.ToString()))</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla participa_grupo.</div>
    }
</div>




@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> docentesDisponibles = new();
    private List<Dictionary<string, object?>> gruposDisponibles = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Campos del formulario
    private string campoCedulaDocente = string.Empty;
    private string campoGrupoId = string.Empty;
    private string campoRol = string.Empty;
    private DateTime? campoFechaInicio = null;
    private DateTime? campoFechaFin = null;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarDocentesDisponibles();
        await CargarGruposDisponibles();
        StateHasChanged(); 
        await CargarRegistros();
    }

    private async Task CargarDocentesDisponibles()
    {
        try
        {
            docentesDisponibles = await Api.ListarAsync("docente", null);
            Console.WriteLine($"Docentes cargados: {docentesDisponibles.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error COMPLETO docentes: {ex}");
            mensaje = $"Error docentes: {ex.Message}";
            exito = false;
        }
    }

    private async Task CargarGruposDisponibles()
    {
        try
        {
            gruposDisponibles = await Api.ListarAsync("grupo_investigacion", null);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar grupos: {ex.Message}");
            mensaje = "Error al cargar los grupos de investigación.";
            exito = false;
        }
    }

    private string ObtenerNombreDocente(string cedula)
    {
        if (string.IsNullOrEmpty(cedula))
            return "N/A";
        
        var docente = docentesDisponibles.FirstOrDefault(d => d["cedula"]?.ToString() == cedula);
        if (docente != null)
        {
            string nombres = docente["nombres"]?.ToString() ?? "";
            string apellidos = docente["apellidos"]?.ToString() ?? "";
            return $"{nombres} {apellidos}".Trim();
        }
        return cedula;
    }

    private string ObtenerNombreGrupo(string grupoId)
    {
        if (string.IsNullOrEmpty(grupoId))
            return "N/A";
        
        var grupo = gruposDisponibles.FirstOrDefault(g => g["id"]?.ToString() == grupoId);
        return grupo?["nombre"]?.ToString() ?? grupoId;
    }

    private string FormatearFecha(string? fecha)
    {
        if (string.IsNullOrEmpty(fecha))
            return "--";
        
        if (DateTime.TryParse(fecha, out var fechaParsed))
        {
            return fechaParsed.ToString("dd/MM/yyyy");
        }
        return fecha;
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("participa_grupo", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoCedulaDocente = string.Empty;
        campoGrupoId = string.Empty;
        campoRol = string.Empty;
        campoFechaInicio = null;
        campoFechaFin = null;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoCedulaDocente = reg["docente_cedula"]?.ToString() ?? "";
        campoGrupoId = reg["grupo_investigacion_id"]?.ToString() ?? "";
        campoRol = reg["rol"]?.ToString() ?? "";
        
        // Convertir fechas string a DateTime?
        string fechaInicio = reg["fecha_inicio"]?.ToString() ?? "";
        campoFechaInicio = string.IsNullOrEmpty(fechaInicio) ? null : DateTime.Parse(fechaInicio);
        
        string fechaFin = reg["fecha_fin"]?.ToString() ?? "";
        campoFechaFin = string.IsNullOrEmpty(fechaFin) ? null : DateTime.Parse(fechaFin);
        
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["docente_cedula"] = campoCedulaDocente,
            ["grupo_investigacion_id"] = campoGrupoId,
            ["rol"] = campoRol,
            ["fecha_inicio"] = campoFechaInicio?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd")
        };

        if (editando)
        {
            datos.Remove("docente_cedula");
            var resultado = await Api.ActualizarAsync("participa_grupo", "docente_cedula", campoCedulaDocente, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("participa_grupo", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string cedulaDocente = reg["docente_cedula"]?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("participa_grupo", "docente_cedula", cedulaDocente);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }

    
    


}