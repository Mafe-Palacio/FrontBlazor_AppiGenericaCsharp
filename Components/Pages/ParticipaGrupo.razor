@page "/participa-grupo"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.SpService Sp
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Participa en Grupo</PageTitle>

<div class="container mt-4">

    @* ───── HEADER ───── *@
    <div class="crud-header">
        <div class="crud-header-left">
            <h2 class="crud-title">
                <i class="bi bi-window-stack"></i>
                Participación de Docentes en Grupos de Investigación
            </h2>
        </div>
        @if (!mostrarFormulario){
            <button class="btn-add" @onclick="NuevoRegistro">
                <i class="bi bi-plus-lg"></i> Nueva Relación
            </button>
        }
    </div>

    @* ───── ALERTA ───── *@
    @if (!string.IsNullOrEmpty(mensaje)){
        <div class="alert-custom @(exito ? "alert-ok" : "alert-err")">
            <i class="bi @(exito ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @mensaje
            <button class="alert-close" @onclick="() => mensaje = string.Empty">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @* -- LISTAR -- *@
    @if (!mostrarFormulario){

        @* Barra de búsqueda *@
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-hash search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por Cédula Docente" @bind="buscarCedula" />
            </div>
            <div class="search-field search-field--wide">
                <i class="bi bi-search search-icon"></i>
                <input type="number" class="search-input" placeholder="Buscar por ID - Grupo Investigación" @bind="buscarIdGrupo" />
            </div>
            <button class="btn-search" @onclick="Buscar">Buscar</button>
            <button class="btn-clear" @onclick="LimpiarBusqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>

        @* Tabla *@
        @if (cargando){
            <div class="loading-wrap">
                <div class="spinner"></div>
                <span>Cargando...</span>
            </div>
        }else if (registros.Any()){
            <div class="table-wrap">
                <table class="crud-table">
                    <thead>
                        <tr>
                            <th class="col-id">Cédula Docente</th>
                            <th>Nombre Docente</th>
                            <th class="col-id">ID Grupo</th>
                            <th>Nombre Grupo</th>
                            <th>Rol</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Fin</th>
                            <th class="col-actions">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in registros){
                            <tr>
                                <td class="col-id">
                                    <span class="id-badge">@r["docente_cedula"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre_docente"]</td>
                                <td class="col-id">
                                    <span class="id-badge">@r["grupo_investigacion_id"]</span>
                                </td>
                                <td class="td-nombre">@r["nombre_grupo"]</td>
                                <td class="td-nombre">@r["rol"]</td>
                                <td>@r["fecha_inicio"]</td>
                                <td>@(r["fecha_fin"] ?? "-")</td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <button class="btn-action btn-delete" title="Eliminar" @onclick="() => EliminarRegistro(r)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }else{
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <p>No hay relaciones activas.</p>
            </div>
        }
    }

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario){
        <div class="form-card">
            <div class="form-card-header">
                Nueva Participación en Grupo
            </div>
           <div class="form-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Docente *</label>
                        <select class="form-select" @bind="campoCedula">
                            <option value="" disabled selected>Seleccione un docente</option>
                            @foreach (var d in docentes){
                                <option value="@d["cedula"]">@d["nombres"] @d["apellidos"] (@d["cedula"])</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Grupo de Investigación *</label>
                        <select class="form-select" @bind="campoIdGrupo">
                            <option value="" disabled selected>Seleccione un grupo de investigación</option>
                            @foreach (var g in grupos){
                                <option value="@g["id"]">@g["nombre"] (@g["id"])</option>
                            }
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Rol *</label>
                        <input class="form-input" @bind="campoRol" maxlength="15" placeholder="Ej: Director, Miembro..." />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha Inicio *</label>
                        <input class="form-input" type="date" @bind="campoFechaInicio" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha Fin</label>
                        <input class="form-input" type="date" @bind="campoFechaFin" />
                    </div>
                </div>
                
                <div class="form-actions">
                    <button class="btn-save" @onclick="GuardarRegistro" disabled="@validacionIncompleta">
                        <i class="bi bi-check-lg"></i> Guardar
                    </button>
                    <button class="btn-cancel" @onclick="Cancelar">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                    <small class="text-muted d-block mt-2">* Campos obligatorios (clave primaria compuesta)</small>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> docentes  = new();
    private List<Dictionary<string, object?>> grupos    = new();
    private bool   cargando = true;
    private bool   mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool   exito = false;

    private int      campoCedula      = 0;
    private int      campoIdGrupo     = 0;
    private string   campoRol         = "";
    private DateTime campoFechaInicio = DateTime.Today;
    private DateTime? campoFechaFin   = null;

    private int? buscarCedula  = null;
    private int? buscarIdGrupo = null;

    private bool validacionIncompleta =>
        campoCedula == 0 || campoIdGrupo == 0 || string.IsNullOrWhiteSpace(campoRol);

    protected override async Task OnInitializedAsync(){
        await CargarSelectores();
        await CargarRegistros();
    }

    private async Task CargarSelectores(){
        var (okD, datosD, _) = await Sp.EjecutarSpAsync("SP_LISTAR_DOCENTES");
        docentes = okD ? datosD : new();

        var (okG, datosG, _) = await Sp.EjecutarSpAsync("SP_LISTAR_GRUPOS_INVESTIGACION");
        grupos = okG ? datosG : new();
    }

    private async Task CargarRegistros(){
        cargando = true;
        var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_LISTAR_PARTICIPA_GRUPO");
        registros = ok ? datos : new();
        if (!ok){
            exito = false;
            mensaje = msg;
        }else if (registros.Count == 0){
            mensaje = "No hay participaciones registradas.";
            exito = true;
        }
        cargando = false;
    }

    private void NuevoRegistro(){
        campoCedula      = 0;
        campoIdGrupo     = 0;
        campoRol         = "";
        campoFechaInicio = DateTime.Today;
        campoFechaFin    = null;
        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRegistro(){
        if (validacionIncompleta){
            exito = false;
            mensaje = "Por favor, complete todos los campos obligatorios.";
            return;
        }

        var datos = new Dictionary<string, object?>{
            ["p_docente_cedula"]         = campoCedula,
            ["p_grupo_investigacion_id"] = campoIdGrupo,
            ["p_rol"]                    = campoRol,
            ["p_fecha_inicio"]           = campoFechaInicio.ToString("yyyy-MM-dd"),
            ["p_fecha_fin"]              = campoFechaFin.HasValue ? campoFechaFin.Value.ToString("yyyy-MM-dd") : null
        };

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_INGRESAR_PARTICIPA_GRUPO", datos);
        exito   = ok;
        mensaje = ok ? "Participación registrada correctamente." : $"Error al guardar: {msg}";

        if (ok){
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> r){
        int cedula  = Convert.ToInt32(r["docente_cedula"]);
        int idGrupo = Convert.ToInt32(r["grupo_investigacion_id"]);

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Confirma que desea eliminar la participación de '{r["nombre_docente"]}' en el grupo '{r["nombre_grupo"]}'?"))
            return;

        var (ok, _, msg) = await Sp.EjecutarSpAsync("SP_ELIMINAR_PARTICIPA_GRUPO", new(){
            ["p_docente_cedula"]         = cedula,
            ["p_grupo_investigacion_id"] = idGrupo
        });

        exito   = ok;
        mensaje = ok ? "Participación eliminada correctamente." : $"Error al eliminar: {msg}";

        if (ok)
            await CargarRegistros();
    }

    private void Cancelar(){
        mostrarFormulario = false;
        mensaje = "";
    }

    private async Task Buscar(){
        if (buscarCedula == null && buscarIdGrupo == null){
            mensaje = "Ingrese la cédula del docente o el ID del grupo para buscar.";
            exito = false;
            return;
        }

        try{
            cargando = true;
            var parametros = new Dictionary<string, object?>{
                ["p_docente_cedula"]         = buscarCedula,
                ["p_grupo_investigacion_id"] = buscarIdGrupo
            };

            var (ok, datos, msg) = await Sp.EjecutarSpAsync("SP_OBTENER_PARTICIPA_GRUPO_POR_ID_GRUPO", parametros);

            registros = ok ? datos : new();

            if (!ok){
                exito = false;
                mensaje = msg;
            }else if (registros.Count == 0){
                mensaje = "No se encontraron coincidencias.";
                exito = false;
            }else{
                mensaje = $"Se encontraron {registros.Count} coincidencias.";
                exito = true;
            }
        }catch (Exception ex){
            exito = false;
            mensaje = $"Error al buscar: {ex.Message}";
        }finally{
            cargando = false;
        }
    }

    private async Task LimpiarBusqueda(){
        buscarCedula  = null;
        buscarIdGrupo = null;
        mensaje = "";
        await CargarRegistros();
    }
}
